    table.header([基线指标], [数值]),
    [提示数 / 每提示采样], [80 / 32],
    [平均确定性], [0.9145],
    [拒答率（全部输出）], [0.8645],
    [高风险指令率（全部输出）], [0.0023],
    [确定性 ≥ 0.95 的提示], [72 / 80],
  ),
  caption: [80 题 gate 的 Qwen3-1.7B 基线],
